\@writefile{toc}{\contentsline {subsubsection}{4.3.8 Medidas de Complexidade Econômica (Extensão v3)}{39}{section*.27}\protected@file@percent }
\newlabel{medidas-de-complexidade-econuxf4mica-extensuxe3o-v3}{{}{39}{4.3.8 Medidas de Complexidade Econômica (Extensão v3)}{section*.27}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Figura 8. Importância de atributos para classificação ARM com 14 features (extensão v3). Painel A: importância Random Forest. Painel B: Permutation importance (20 repetições). As três novas features de complexidade econômica são destacadas em vermelho: product\_density (2º lugar, 12,86\%), knowledge\_complexity (3º lugar, 8,88\%) e export\_sophistication (10º lugar, 5,26\%). O ganho preditivo da inclusão destas medidas é modesto, porém consistente com a literatura que aponta a complexidade econômica como determinante de longo prazo do desenvolvimento.}}{40}{figure.8}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Figura 9. Densidade produtiva por grupo de renda e relação com PIB per capita. Painel A: distribuição de product\_density por grupo de renda, com gradiente crescente de baixa para alta renda. Painel B: relação entre product\_density e PIB per capita, com destaque para países em ARM relativo (X vermelho). Países ARM concentram-se na faixa de densidade 0,2-0,6 --- a ``zona de transição'' onde a proximidade à fronteira tecnológica ainda é insuficiente para garantir convergência.}}{41}{figure.9}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Figura 10. Complexidade do conhecimento (KCI proxy) e perfis de desenvolvimento. Painel A: relação entre knowledge\_complexity e PIB per capita, com destaque para países ARM (X vermelho). A correlação é forte (r = 0,77). Painel B: distribuição da complexidade do conhecimento por cluster k-means, revelando que países do cluster de alta renda (C2) concentram KCI elevado, enquanto países ARM limitam-se a KCI abaixo de 1,5.}}{42}{figure.10}\protected@file@percent }
