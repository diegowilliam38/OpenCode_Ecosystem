# ─── ARANEA — Environment Configuration ───────────────────────────────────
# Copy this file to .env and fill in your API keys.
# Only ANTHROPIC_API_KEY is required if using Claude. All others are optional.

# ─── LLM Provider (choose one or both) ────────────────────────────────────

# Anthropic Claude API (primary — required for full pipeline)
# Get your key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Ollama (local fallback — no key needed)
# Install: https://ollama.com/download
# Then: ollama pull qwen2.5:14b
# The pipeline auto-detects Ollama on localhost:11434
# OLLAMA_HOST=http://localhost:11434

# ─── Academic Source APIs ──────────────────────────────────────────────────

# OpenAlex (free, no key needed for basic use)
# For polite pool (faster): add your email
# OPENALEX_EMAIL=you@university.edu

# Semantic Scholar (free, no key needed)
# For higher rate limits: https://www.semanticscholar.org/product/api
# S2_API_KEY=

# Scopus (requires institutional access)
# Key: https://dev.elsevier.com/
# SCOPUS_API_KEY=
# SCOPUS_INST_TOKEN=

# ─── Consensus (MCP OAuth — no API key needed) ────────────────────────────
# Consensus uses OAuth 2.1 via MCP. On first run, a browser window opens
# for you to log in with your Consensus account. Tokens are saved to
# db/consensus_tokens.json and reused automatically.
# Pro plan gives 20 results/search, 1000 searches/month.
# Disabled by default in config.json — enable in agent_sources to use.
