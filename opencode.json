{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/big-pickle",
  "small_model": "opencode/big-pickle",
  "autoupdate": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "plugin": [
    "plugins/ecosystem-sync.ts",
    "plugins/manus-evolve.ts",
    "plugins/bernstein-sync.ts",
    "plugins/antigravity-bridge.ts",
    "plugins/cora-qscore.ts"
  ],
  "mcp": {
    "filesystem": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:\\Users\\marce"
      ],
      "tags": [
        "core",
        "files"
      ]
    },
    "code-runner": {
      "type": "local",
      "enabled": true,
      "command": [
        "mcp-server-code-runner"
      ],
      "tags": [
        "core",
        "execution"
      ]
    },
    "mcp-python-interpreter": {
      "type": "local",
      "enabled": true,
      "command": [
        "mcp-python-interpreter"
      ],
      "tags": [
        "core",
        "python",
        "execution"
      ]
    },
    "sqlite": {
      "type": "local",
      "enabled": true,
      "command": [
        "mcp-server-sqlite"
      ],
      "tags": [
        "core",
        "database"
      ]
    },
    "sequential-thinking": {
      "type": "local",
      "enabled": true,
      "command": [
        "node",
        "C:/Users/marce/AppData/Roaming/npm/node_modules/@modelcontextprotocol/server-sequential-thinking/dist/index.js"
      ],
      "tags": [
        "core",
        "reasoning"
      ]
    },
    "websearch": {
      "type": "local",
      "enabled": true,
      "command": [
        "mcp-fetch-server",
        "--duckduckgo"
      ],
      "tags": [
        "search",
        "web"
      ]
    },
    "fetch": {
      "type": "local",
      "enabled": true,
      "command": [
        "mcp-fetch-server"
      ],
      "tags": [
        "search",
        "web"
      ]
    },
    "wikipedia": {
      "type": "local",
      "enabled": false,
      "command": [
        "npx",
        "-y",
        "mcp-wikipedia"
      ],
      "tags": [
        "search",
        "encyclopedia"
      ]
    },
    "context7": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.context7.com/mcp",
      "tags": [
        "search",
        "docs"
      ]
    },
    "gh_grep": {
      "type": "remote",
      "enabled": true,
