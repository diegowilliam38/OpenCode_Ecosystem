# =============================================================================
# editais-br — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env
# =============================================================================

# --- API de IA — DeepSeek ---
DEEPSEEK_API_KEY=                      # deepseek-v4-flash e deepseek-v4-pro
# base_url: https://api.deepseek.com (OpenAI-compatible)

# --- Banco de dados ---
POSTGRES_USER=editais
POSTGRES_PASSWORD=changeme
POSTGRES_DB=editais
POSTGRES_URL=postgresql://editais:changeme@postgres:5432/editais

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- API ---
SECRET_KEY=changeme-generate-a-real-secret
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Portais com login (opcional) ---
CNPQ_EMAIL=
CNPQ_PASSWORD=

# --- Scraping ---
SCRAPER_RATE_LIMIT_SECONDS=3           # delay mínimo entre requisições por domínio
SCRAPER_MAX_RETRIES=3

# --- Celery ---
CELERY_CONCURRENCY=4                   # workers paralelos
