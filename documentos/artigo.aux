\@writefile{toc}{\contentsline {subsection}{O modelo de 58 agentes segue a lei de Conway (1968) adaptada para sistemas multiagente, onde a estrutura do sistema reflete a estrutura de comunicacao entre seus componentes. A distribuicao em 5 categorias (Core, Reversa, Workshop, Especializados, Gestao) otimiza a comunicacao intragrupo (alta coesao) e minimiza a comunicacao intergrupo (baixo acoplamento), principios fundamentais de engenharia de software (Pressman, 2014; Sommerville, 2015).}{24}{section*.18}\protected@file@percent }
\newlabel{o-modelo-de-58-agentes-segue-a-lei-de-conway-1968-adaptada-para-sistemas-multiagente-onde-a-estrutura-do-sistema-reflete-a-estrutura-de-comunicacao-entre-seus-componentes.-a-distribuicao-em-5-categorias-core-reversa-workshop-especializados-gestao-otimiza-a-comunicacao-intragrupo-alta-coesao-e-minimiza-a-comunicacao-intergrupo-baixo-acoplamento-principios-fundamentais-de-engenharia-de-software-pressman-2014-sommerville-2015.}{{}{24}{O modelo de 58 agentes segue a lei de Conway (1968) adaptada para sistemas multiagente, onde a estrutura do sistema reflete a estrutura de comunicacao entre seus componentes. A distribuicao em 5 categorias (Core, Reversa, Workshop, Especializados, Gestao) otimiza a comunicacao intragrupo (alta coesao) e minimiza a comunicacao intergrupo (baixo acoplamento), principios fundamentais de engenharia de software (Pressman, 2014; Sommerville, 2015)}{section*.18}{}}
