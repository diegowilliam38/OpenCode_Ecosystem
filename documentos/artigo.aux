\@writefile{toc}{\contentsline {subsection}{O mecanismo de progressive disclosure (skill-progressive-disclosure-design) implementa o padrao de mesmo nome descrito por Lidwell et al.~(2010), onde informacao complexa e revelada progressivamente para otimizar o uso do espaco de contexto. Skills com mais de 2.5KB utilizam arquivos de referencia (references/) para armazenar detalhes operacionais, mantendo o SKILL.md focado em disparo e workflow principal.}{19}{section*.14}\protected@file@percent }
\newlabel{o-mecanismo-de-progressive-disclosure-skill-progressive-disclosure-design-implementa-o-padrao-de-mesmo-nome-descrito-por-lidwell-et-al.-2010-onde-informacao-complexa-e-revelada-progressivamente-para-otimizar-o-uso-do-espaco-de-contexto.-skills-com-mais-de-2.5kb-utilizam-arquivos-de-referencia-references-para-armazenar-detalhes-operacionais-mantendo-o-skill.md-focado-em-disparo-e-workflow-principal.}{{}{19}{O mecanismo de progressive disclosure (skill-progressive-disclosure-design) implementa o padrao de mesmo nome descrito por Lidwell et al.~(2010), onde informacao complexa e revelada progressivamente para otimizar o uso do espaco de contexto. Skills com mais de 2.5KB utilizam arquivos de referencia (references/) para armazenar detalhes operacionais, mantendo o SKILL.md focado em disparo e workflow principal}{section*.14}{}}
