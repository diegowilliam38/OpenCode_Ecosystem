\@writefile{toc}{\contentsline {subsection}{O feedback loop via SQLite (--feedback flag) e treinamento (--treinar flag) implementa aprendizado continuo, onde pesos de classificacao sao ajustados conforme o usuario fornece feedback sobre resultados recomendados. Este mecanismo segue o paradigma de aprendizado por reforco (Sutton e Barto, 2018), onde recompensas (feedback positivo) e punicoes (feedback negativo) ajustam a politica de recomendacao.}{63}{section*.55}\protected@file@percent }
\newlabel{o-feedback-loop-via-sqlite-feedback-flag-e-treinamento-treinar-flag-implementa-aprendizado-continuo-onde-pesos-de-classificacao-sao-ajustados-conforme-o-usuario-fornece-feedback-sobre-resultados-recomendados.-este-mecanismo-segue-o-paradigma-de-aprendizado-por-reforco-sutton-e-barto-2018-onde-recompensas-feedback-positivo-e-punicoes-feedback-negativo-ajustam-a-politica-de-recomendacao.}{{}{63}{O feedback loop via SQLite (--feedback flag) e treinamento (--treinar flag) implementa aprendizado continuo, onde pesos de classificacao sao ajustados conforme o usuario fornece feedback sobre resultados recomendados. Este mecanismo segue o paradigma de aprendizado por reforco (Sutton e Barto, 2018), onde recompensas (feedback positivo) e punicoes (feedback negativo) ajustam a politica de recomendacao}{section*.55}{}}
